# =============================================================================
# Eficyent API - Environment configuration
# =============================================================================
# This file has TWO sets of values:
#
#   1. PRODUCTION values (top half) - non-sensitive bootstrap only. All real
#      secrets live in AWS Secrets Manager and are loaded at boot.
#
#   2. DEV values (bottom half, behind a comment block) - flips the API to
#      "dev mode" by setting DATABASE_URL. In dev mode every secret bundle
#      reads from env vars directly so AWS credentials are NOT required to
#      run the API locally.
#
# Production: leave the dev section commented out. Set the SECRET_ID_*
# values + KMS_KEY_ID, run on EC2/ECS/EKS with an instance role.
#
# Dev: copy to `.env`, uncomment the dev section, point REDIS_HOST + the
# DATABASE_URL at your local Docker containers.
# =============================================================================

NODE_ENV=production
APP_NAME=Eficyent
APP_ENV=production
APP_DEBUG=false
APP_URL=https://api.eficyent.example.com
PORT=8080

# Trust proxy hops (ALB / CloudFront). 0 disables, 1 = single LB, true = all.
TRUST_PROXY=1

# ----------------------------------------------------------------------------
# AWS Secrets Manager + KMS  (production only)
# ----------------------------------------------------------------------------
AWS_REGION=us-east-1

# KMS key used for envelope-encrypting at-rest sensitive columns
# (TFA secrets, refresh tokens, beneficiary PII, external service tokens).
# Must be a KMS key ARN or alias - NOT a Secrets Manager ARN.
KMS_KEY_ID=alias/eficyent/${APP_ENV}/app

# Secret IDs (proposed convention):
#   eficyent/<env>/app           - APP_KEY, signing keys, internal secrets
#   eficyent/<env>/db            - DB connection (host, port, user, pass, db)
#   eficyent/<env>/redis         - Redis connection (host, port, auth, tls)
#   eficyent/<env>/auth          - hash pepper, token pepper, signature secrets
#   eficyent/<env>/aws           - S3 bucket, kms config (non-credential)
#   eficyent/<env>/mail          - mailer credentials
#   eficyent/<env>/external/<provider>  - per-provider API keys (caliza, diginine, fvbank, ...)
SECRET_ID_APP=eficyent/production/app
SECRET_ID_DB=eficyent/production/db
SECRET_ID_REDIS=eficyent/production/redis
SECRET_ID_AUTH=eficyent/production/auth
SECRET_ID_AWS=eficyent/production/aws
SECRET_ID_MAIL=eficyent/production/mail
SECRET_ID_EXTERNAL_PREFIX=eficyent/production/external

SECRETS_CACHE_TTL_MS=300000

# ----------------------------------------------------------------------------
# Logging
# ----------------------------------------------------------------------------
LOG_LEVEL=info

# ----------------------------------------------------------------------------
# Security
# ----------------------------------------------------------------------------
CORS_ORIGINS=https://app.eficyent.example.com,https://admin.eficyent.example.com
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
RATE_LIMIT_LIMITED_MAX=10
REQUEST_BODY_LIMIT_KB=1024

# Auth
SESSION_TTL_SECONDS=86400
SESSION_INACTIVITY_TTL_SECONDS=3600
SESSION_ABSOLUTE_TTL_SECONDS=604800
TOKEN_BYTES=40

# Idempotency (Redis-backed)
IDEMPOTENCY_TTL_SECONDS=86400

# ----------------------------------------------------------------------------
# BullMQ - one variable per queue, set concurrency and (where applicable) cron
# ----------------------------------------------------------------------------
BULLMQ_PREFIX=eficyent

# Concurrency per queue
BULLMQ_PAYOUT_CONCURRENCY=8
BULLMQ_DEPOSIT_CONCURRENCY=8
BULLMQ_COMPLIANCE_CONCURRENCY=4
BULLMQ_REMITTANCE_CONCURRENCY=4
BULLMQ_BENEFICIARY_VALIDATION_CONCURRENCY=4
BULLMQ_FX_RATES_CONCURRENCY=1
BULLMQ_CALLBACK_CONCURRENCY=8
BULLMQ_FVBANK_VA_CONCURRENCY=2
BULLMQ_INVOICEMATE_CONCURRENCY=2
BULLMQ_BULK_PAYOUT_CONCURRENCY=2
BULLMQ_USER_ALERT_CONCURRENCY=2
BULLMQ_CALIZA_WEBHOOK_CONCURRENCY=4
BULLMQ_DIGININE_WEBHOOK_CONCURRENCY=4
BULLMQ_DEBIT_NOTIFICATION_CONCURRENCY=2
BULLMQ_COMPLIANCE_BATCH_CONCURRENCY=1
BULLMQ_REMITTANCE_BATCH_CONCURRENCY=1

# Job retry/backoff
BULLMQ_DEFAULT_ATTEMPTS=5
BULLMQ_DEFAULT_BACKOFF_MS=2000

# Crons (UTC). All crons are also runnable on demand via the API for ops.
CRON_FX_RATES=*/30 * * * *
CRON_CHECK_BENEFICIARY_TXN_STATUS=*/5 * * * *
CRON_DIGININE_COUNTRY_SYNC=0 3 * * *
CRON_FETCH_FVBANK_VA=*/15 * * * *
CRON_PAYOUT_JOB_REAPER=*/2 * * * *

# Run cron registration only on this hostname (avoids duplicates with multiple workers).
# Empty = all worker processes register crons (safe for BullMQ - it deduplicates by jobId).
CRON_LEADER_HOST=

# ----------------------------------------------------------------------------
# Sandbox flag (mirrors Laravel's app.is_sandbox)
# ----------------------------------------------------------------------------
APP_IS_SANDBOX=false


# =============================================================================
# DEV MODE - uncomment everything below to skip AWS Secrets Manager and run
# the API directly against local MySQL + Redis. Setting DATABASE_URL is what
# flips the switch; the rest are env-based replacements for the AWS bundles.
# =============================================================================

# NODE_ENV=dev
# APP_ENV=dev
# APP_URL=http://localhost:8080
# CORS_ORIGINS=http://localhost:3000

# # 1. Database (Prisma reads DATABASE_URL directly)
# DATABASE_URL="mysql://root:codegama%40123@127.0.0.1:3306/eficyent_node"

# # 2. Redis (used by sessions, rate-limit, idempotency, BullMQ)
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# # REDIS_PASSWORD=
# # REDIS_USERNAME=
# REDIS_DB=0
# REDIS_TLS=false

# # 3. Auth pepper + signature secrets. Generate with: openssl rand -hex 32
# TOKEN_PEPPER=replace-with-openssl-rand-hex-32
# PASSWORD_PEPPER=replace-with-openssl-rand-hex-32
# SIGNATURE_SECRET=replace-with-openssl-rand-hex-32
# MERCHANT_SIGNATURE_SECRET=replace-with-openssl-rand-hex-32

# # 4. App key + webhook signing secrets
# APP_KEY=replace-with-openssl-rand-base64-32
# REQUEST_SIGNING_SECRET=replace-with-openssl-rand-hex-32
# FVBANK_WEBHOOK_SECRET=replace-with-openssl-rand-hex-32

# # 5. Mail (optional - leave blank to no-op send)
# MAIL_HOST=localhost
# MAIL_PORT=1025
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_FROM=no-reply@local

# # 6. S3 (optional - only required for endpoints that upload/download)
# # S3_BUCKET=eficyent-dev
# # S3_REGION=us-east-1
# # S3_USE_PATH_STYLE=true

# # 7. External providers (only when you actually invoke them in dev). The
# # value MUST be the full JSON the production secret would hold; e.g.:
# # EXTERNAL_CALIZA_JSON={"CALLBACK_URL":"https://example.invalid"}
# # EXTERNAL_DIGININE_JSON={"CALLBACK_URL":"https://example.invalid"}
# # EXTERNAL_FVBANK_JSON={"CLIENT_SECRET":"hexhex"}
# # EXTERNAL_REPORT_SERVER_JSON={"BASE_URL":"https://reports.invalid","HEADER_KEY":"x-api-key","HEADER_VALUE":"k"}

# # KMS - in dev, encrypted columns use a local AES-256-GCM key derived
# # from APP_KEY (see config/kms.ts). Leave KMS_KEY_ID empty.
# KMS_KEY_ID=

# # SECRET_ID_* don't have to be valid in dev mode (they're never read), but
# # leaving them set is harmless.
