# =============================================================================
# Eficyent API - Environment configuration
# =============================================================================
# Resolution rule: SECRET > ENV > built-in default.
#
# Every value below can live in env, or in your AWS Secrets Manager bundle,
# or both (secret wins). Adding a new key in the AWS secret picks it up
# automatically with no code change - see src/config/secrets.ts for the
# recognised keys.
# =============================================================================

NODE_ENV=production
APP_NAME=Eficyent
APP_ENV=production
APP_DEBUG=false
APP_URL=https://api.eficyent.example.com
PORT=8080

# Trust proxy hops (ALB / CloudFront). 0 disables, 1 = single LB, true = all.
TRUST_PROXY=1

# ----------------------------------------------------------------------------
# AWS Secrets Manager (optional - set in production)
# ----------------------------------------------------------------------------
# When SECRET_ID_BUNDLE is set, the named secret is loaded once at boot
# as a flat JSON object and takes priority over the env keys below.
# Leave it blank for local development.
AWS_REGION=us-east-1
SECRET_ID_BUNDLE=
SECRETS_CACHE_TTL_MS=300000

# KMS - leave empty for local AES-256-GCM (key derived from APP_KEY).
# In production set to a real KMS key ARN/alias.
KMS_KEY_ID=

# ----------------------------------------------------------------------------
# Application secrets
# Generate with: openssl rand -base64 32   (APP_KEY)
#                openssl rand -hex 32      (everything else)
# ----------------------------------------------------------------------------
APP_KEY=
REQUEST_SIGNING_SECRET=
FVBANK_WEBHOOK_SECRET=

TOKEN_PEPPER=
PASSWORD_PEPPER=
SIGNATURE_SECRET=
MERCHANT_SIGNATURE_SECRET=

# ----------------------------------------------------------------------------
# Database. Either DATABASE_URL or the DB_* parts. DATABASE_URL wins
# when both are set. Special characters in the password do NOT need
# URL-encoding when using DB_PASSWORD - we encode for you.
# ----------------------------------------------------------------------------
# DATABASE_URL=mysql://root:codegama%40123@127.0.0.1:3306/eficyent
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=eficyent
DB_USERNAME=root
DB_PASSWORD=
DB_SSL=false

# ----------------------------------------------------------------------------
# Redis (sessions, rate-limit, idempotency, BullMQ)
# ----------------------------------------------------------------------------
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_USERNAME=
REDIS_TLS=false
REDIS_DB=0

# ----------------------------------------------------------------------------
# S3 (used for file uploads / receipt downloads)
# ----------------------------------------------------------------------------
S3_BUCKET=
S3_REGION=us-east-1
S3_USE_PATH_STYLE=false

# ----------------------------------------------------------------------------
# Mail (nodemailer SMTP)
# ----------------------------------------------------------------------------
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=

# ----------------------------------------------------------------------------
# External providers - one EXTERNAL_<PROVIDER>_<KEY> entry per setting.
# Adding new keys here (or in the AWS secret) is automatic - the consumer
# just reads the new key off the returned object.
#
# Provider names map to the prefix:
#     caliza, compliance, diginine, fvbank, herald_sumsub, incode,
#     invoicemate, massive, processingunit, remittance, report_server,
#     surepass, telegram, viyona_pay
# ----------------------------------------------------------------------------
# EXTERNAL_CALIZA_URL=
# EXTERNAL_CALIZA_API_KEY=
# EXTERNAL_CALIZA_CALLBACK_URL=

# EXTERNAL_DIGININE_URL=
# EXTERNAL_DIGININE_API_KEY=
# EXTERNAL_DIGININE_CALLBACK_URL=

# EXTERNAL_FVBANK_URL=
# EXTERNAL_FVBANK_API_KEY=
# EXTERNAL_FVBANK_CLIENT_SECRET=

# EXTERNAL_MASSIVE_URL=https://bertdgh-services.herald.exchange
# EXTERNAL_MASSIVE_API_KEY=
# EXTERNAL_MASSIVE_GET_QUOTE_ENDPOINT=/api/v1/exchange/rate

# EXTERNAL_COMPLIANCE_URL=https://sandbox-api-compliance.herald.exchange
# EXTERNAL_COMPLIANCE_API_KEY=
# EXTERNAL_COMPLIANCE_CREATE_TRANSACTION_ENDPOINT=/transactions
# EXTERNAL_COMPLIANCE_EMAIL=
# EXTERNAL_COMPLIANCE_PASSWORD=
# EXTERNAL_COMPLIANCE_ACCESS_TOKEN_ENDPOINT=/api/v1/auth/login
# EXTERNAL_COMPLIANCE_TIMEOUT_SEC=90

# EXTERNAL_PROCESSINGUNIT_URL=
# EXTERNAL_PROCESSINGUNIT_API_KEY=
# EXTERNAL_PROCESSINGUNIT_API_SECRET=

# EXTERNAL_REPORT_SERVER_BASE_URL=
# EXTERNAL_REPORT_SERVER_HEADER_KEY=x-api-key
# EXTERNAL_REPORT_SERVER_HEADER_VALUE=
# EXTERNAL_REPORT_SERVER_VIYONAPAY=
# EXTERNAL_REPORT_SERVER_DIGININE=

# ----------------------------------------------------------------------------
# Logging
# ----------------------------------------------------------------------------
LOG_LEVEL=info

# ----------------------------------------------------------------------------
# Security
# ----------------------------------------------------------------------------
CORS_ORIGINS=https://app.eficyent.example.com,https://admin.eficyent.example.com
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
RATE_LIMIT_LIMITED_MAX=10
REQUEST_BODY_LIMIT_KB=1024

# Auth
SESSION_TTL_SECONDS=86400
SESSION_INACTIVITY_TTL_SECONDS=3600
SESSION_ABSOLUTE_TTL_SECONDS=604800
TOKEN_BYTES=40

# Idempotency (Redis-backed)
IDEMPOTENCY_TTL_SECONDS=86400

# ----------------------------------------------------------------------------
# BullMQ - one variable per queue, set concurrency and (where applicable) cron
# ----------------------------------------------------------------------------
BULLMQ_PREFIX=eficyent

BULLMQ_PAYOUT_CONCURRENCY=8
BULLMQ_DEPOSIT_CONCURRENCY=8
BULLMQ_COMPLIANCE_CONCURRENCY=4
BULLMQ_REMITTANCE_CONCURRENCY=4
BULLMQ_BENEFICIARY_VALIDATION_CONCURRENCY=4
BULLMQ_FX_RATES_CONCURRENCY=1
BULLMQ_CALLBACK_CONCURRENCY=8
BULLMQ_FVBANK_VA_CONCURRENCY=2
BULLMQ_INVOICEMATE_CONCURRENCY=2
BULLMQ_BULK_PAYOUT_CONCURRENCY=2
BULLMQ_USER_ALERT_CONCURRENCY=2
BULLMQ_CALIZA_WEBHOOK_CONCURRENCY=4
BULLMQ_DIGININE_WEBHOOK_CONCURRENCY=4
BULLMQ_DEBIT_NOTIFICATION_CONCURRENCY=2
BULLMQ_COMPLIANCE_BATCH_CONCURRENCY=1
BULLMQ_REMITTANCE_BATCH_CONCURRENCY=1

BULLMQ_DEFAULT_ATTEMPTS=5
BULLMQ_DEFAULT_BACKOFF_MS=2000

# Crons (UTC). All crons are also runnable on demand via the API for ops.
CRON_FX_RATES=*/30 * * * *
CRON_CHECK_BENEFICIARY_TXN_STATUS=*/5 * * * *
CRON_DIGININE_COUNTRY_SYNC=0 3 * * *
CRON_FETCH_FVBANK_VA=*/15 * * * *
CRON_PAYOUT_JOB_REAPER=*/2 * * * *
CRON_LEADER_HOST=

APP_IS_SANDBOX=false

# ----------------------------------------------------------------------------
# AED rate override (Massive provider only quotes USD; AED rates are
# derived by dividing the USD rate by USD_TO_AED).
# ----------------------------------------------------------------------------
USD_TO_AED=2.67
