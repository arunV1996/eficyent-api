# =============================================================================
# Eficyent API - Environment configuration
# =============================================================================
# Two boot modes are supported. Pick ONE:
#
#   LOCAL  -> set DATABASE_URL (and the other LOCAL block vars below).
#             Every secret is read from env, no AWS at all.
#             KMS is bypassed; encrypted columns use a local AES key
#             derived from APP_KEY (tagged with the v1d prefix).
#
#   PROD   -> leave DATABASE_URL unset, set SECRET_ID_BUNDLE to your
#             AWS Secrets Manager secret ARN/name, set KMS_KEY_ID to a
#             real KMS key ARN/alias. The bundled secret holds DB,
#             Redis, auth, app, mail, AWS, and external-provider keys.
# =============================================================================

NODE_ENV=production
APP_NAME=Eficyent
APP_ENV=production
APP_DEBUG=false
APP_URL=https://api.eficyent.example.com
PORT=8080

# Trust proxy hops (ALB / CloudFront). 0 disables, 1 = single LB, true = all.
TRUST_PROXY=1

# ----------------------------------------------------------------------------
# Logging / security / sessions / queues / crons (apply in BOTH modes)
# ----------------------------------------------------------------------------
LOG_LEVEL=info

CORS_ORIGINS=https://app.eficyent.example.com,https://admin.eficyent.example.com
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
RATE_LIMIT_LIMITED_MAX=10
REQUEST_BODY_LIMIT_KB=1024

SESSION_TTL_SECONDS=86400
SESSION_INACTIVITY_TTL_SECONDS=3600
SESSION_ABSOLUTE_TTL_SECONDS=604800
TOKEN_BYTES=40

IDEMPOTENCY_TTL_SECONDS=86400

BULLMQ_PREFIX=eficyent
BULLMQ_PAYOUT_CONCURRENCY=8
BULLMQ_DEPOSIT_CONCURRENCY=8
BULLMQ_COMPLIANCE_CONCURRENCY=4
BULLMQ_REMITTANCE_CONCURRENCY=4
BULLMQ_BENEFICIARY_VALIDATION_CONCURRENCY=4
BULLMQ_FX_RATES_CONCURRENCY=1
BULLMQ_CALLBACK_CONCURRENCY=8
BULLMQ_FVBANK_VA_CONCURRENCY=2
BULLMQ_INVOICEMATE_CONCURRENCY=2
BULLMQ_BULK_PAYOUT_CONCURRENCY=2
BULLMQ_USER_ALERT_CONCURRENCY=2
BULLMQ_CALIZA_WEBHOOK_CONCURRENCY=4
BULLMQ_DIGININE_WEBHOOK_CONCURRENCY=4
BULLMQ_DEBIT_NOTIFICATION_CONCURRENCY=2
BULLMQ_COMPLIANCE_BATCH_CONCURRENCY=1
BULLMQ_REMITTANCE_BATCH_CONCURRENCY=1
BULLMQ_DEFAULT_ATTEMPTS=5
BULLMQ_DEFAULT_BACKOFF_MS=2000

CRON_FX_RATES=*/30 * * * *
CRON_CHECK_BENEFICIARY_TXN_STATUS=*/5 * * * *
CRON_DIGININE_COUNTRY_SYNC=0 3 * * *
CRON_FETCH_FVBANK_VA=*/15 * * * *
CRON_PAYOUT_JOB_REAPER=*/2 * * * *
CRON_LEADER_HOST=

APP_IS_SANDBOX=false


# =============================================================================
# PROD MODE - one bundled AWS Secrets Manager secret + real KMS
# =============================================================================
# 1. Create a Secrets Manager secret (any name) and paste this JSON into the
#    SecretString:
#
#    {
#      "app":   { "APP_KEY": "<base64-32>", "REQUEST_SIGNING_SECRET": "<hex-32>", "FVBANK_WEBHOOK_SECRET": "<hex-32>" },
#      "db":    { "host": "...", "port": 3306, "database": "...", "username": "...", "password": "...", "ssl": true },
#      "redis": { "host": "...", "port": 6379, "password": "...", "tls": true, "username": "default" },
#      "auth":  { "TOKEN_PEPPER": "<hex-32>", "PASSWORD_PEPPER": "<hex-32>", "SIGNATURE_SECRET": "<hex-32>", "MERCHANT_SIGNATURE_SECRET": "<hex-32>" },
#      "aws":   { "S3_BUCKET": "...", "S3_REGION": "us-east-1", "S3_USE_PATH_STYLE": false },
#      "mail":  { "host": "...", "port": 587, "username": "...", "password": "...", "from": "no-reply@..." },
#      "external": {
#        "caliza":        { "URL": "...", "API_KEY": "...", "CALLBACK_URL": "..." },
#        "diginine":      { "URL": "...", "API_KEY": "...", "CALLBACK_URL": "..." },
#        "fvbank":        { "URL": "...", "API_KEY": "...", "CLIENT_SECRET": "..." },
#        "massive":       { "URL": "...", "API_KEY": "...", "GET_QUOTE_ENDPOINT": "/quote" },
#        "compliance":    { "URL": "...", "API_KEY": "...", "CREATE_TRANSACTION_ENDPOINT": "/transactions" },
#        "processing_unit": { "URL": "...", "API_KEY": "...", "API_SECRET": "..." },
#        "report_server": { "BASE_URL": "...", "HEADER_KEY": "x-api-key", "HEADER_VALUE": "...", "VIYONAPAY": "...", "DIGININE": "..." }
#      }
#    }
#
# 2. Generate the random values with:
#      openssl rand -hex 32      # for *_PEPPER, *_SECRET
#      openssl rand -base64 32   # for APP_KEY
#
# 3. Set the env vars below to point at the secret + KMS key:

AWS_REGION=us-east-1
SECRET_ID_BUNDLE=arn:aws:secretsmanager:us-east-1:529946104689:secret:eficyent-api-staging-pjtQzE
KMS_KEY_ID=arn:aws:kms:us-east-1:529946104689:key/<replace-with-real-kms-key-uuid>
SECRETS_CACHE_TTL_MS=300000


# =============================================================================
# LOCAL MODE - uncomment everything below to skip AWS entirely
# =============================================================================
# Setting DATABASE_URL flips the API into local mode. Leave SECRET_ID_BUNDLE
# unset (or comment it out above). KMS_KEY_ID empty -> local AES crypto.

# NODE_ENV=dev
# APP_ENV=dev
# APP_URL=http://localhost:8080
# CORS_ORIGINS=http://localhost:3000

# # 1. Database (Prisma reads DATABASE_URL directly)
# DATABASE_URL="mysql://root:codegama%40123@127.0.0.1:3306/eficyent_node"

# # 2. Redis (sessions, rate-limit, idempotency, BullMQ)
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# # REDIS_PASSWORD=
# # REDIS_USERNAME=
# REDIS_DB=0
# REDIS_TLS=false

# # 3. Auth pepper + signature secrets. Generate with: openssl rand -hex 32
# TOKEN_PEPPER=replace-with-openssl-rand-hex-32
# PASSWORD_PEPPER=replace-with-openssl-rand-hex-32
# SIGNATURE_SECRET=replace-with-openssl-rand-hex-32
# MERCHANT_SIGNATURE_SECRET=replace-with-openssl-rand-hex-32

# # 4. App key + webhook signing secrets. Generate with: openssl rand -base64 32
# APP_KEY=replace-with-openssl-rand-base64-32
# REQUEST_SIGNING_SECRET=replace-with-openssl-rand-hex-32
# FVBANK_WEBHOOK_SECRET=replace-with-openssl-rand-hex-32

# # 5. Mail (optional)
# MAIL_HOST=localhost
# MAIL_PORT=1025
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_FROM=no-reply@local

# # 6. S3 (optional - only required for endpoints that upload/download)
# # S3_BUCKET=eficyent-dev
# # S3_REGION=us-east-1
# # S3_USE_PATH_STYLE=true

# # 7. External providers (only when you actually invoke them in dev). The
# # value MUST be the full JSON object the production secret would hold.
# # EXTERNAL_CALIZA_JSON={"URL":"https://...","API_KEY":"...","CALLBACK_URL":"https://..."}
# # EXTERNAL_FVBANK_JSON={"CLIENT_SECRET":"hexhex"}
# # EXTERNAL_REPORT_SERVER_JSON={"BASE_URL":"https://reports.invalid","HEADER_KEY":"x-api-key","HEADER_VALUE":"k"}

# # 8. KMS - leave empty in local mode. Encrypted columns use a local AES
# # key derived from APP_KEY; ciphertext is tagged v1d so prod won't try
# # to decrypt it through KMS.
# # KMS_KEY_ID=
