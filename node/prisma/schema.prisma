  @@index([teamMemberId], map: "deposit_transactions_team_member_id_foreign")
  @@index([userId], map: "deposit_transactions_user_id_foreign")
  @@index([virtualAccountId], map: "deposit_transactions_virtual_account_id_foreign")
  @@map("deposit_transactions")
