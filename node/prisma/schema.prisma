generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                                     BigInt                              @id @default(autoincrement()) @db.UnsignedBigInt
  uniqueId                               String                              @unique(map: "users_unique_id_unique") @map("unique_id") @db.VarChar(255)
  merchantId                             BigInt?                             @map("merchant_id") @db.UnsignedBigInt
  businessUserId                         BigInt?                             @map("business_user_id") @db.UnsignedBigInt
  title                                  String?                             @db.VarChar(5)
  firstName                              String?                             @map("first_name") @db.VarChar(100)
  middleName                             String?                             @map("middle_name") @db.VarChar(100)
  lastName                               String?                             @map("last_name") @db.VarChar(100)
  email                                  String                              @unique(map: "users_email_unique") @db.VarChar(255)
  emailCode                              String?                             @map("email_code") @db.VarChar(255)
  emailCodeExpiry                        String?                             @map("email_code_expiry") @db.VarChar(255)
  emailVerifiedAt                        DateTime?                           @map("email_verified_at") @db.Timestamp(0)
  mobileCountryCode                      String?                             @map("mobile_country_code") @db.VarChar(255)
  mobile                                 String?                             @unique(map: "users_mobile_unique") @db.VarChar(255)
  password                               String?                             @db.VarChar(255)
  isTfaSetupCompleted                    Int                                 @default(0) @map("is_tfa_setup_completed") @db.TinyInt
  isTfaEnabled                           Int                                 @default(0) @map("is_tfa_enabled") @db.TinyInt
  backupCodes                            String?                             @map("backup_codes") @db.Text
  tfaSecret                              String?                             @map("tfa_secret") @db.Text
  gender                                 String?                             @db.VarChar(5)
  dob                                    DateTime?                           @db.Date
  picture                                String                              @default("http://localhost/placeholders/placeholder.png") @db.VarChar(255)
  userType                               Int                                 @default(0) @map("user_type") @db.TinyInt
  serviceProviders                       Json?                               @map("service_providers")
  userRole                               Int?                                @map("user_role") @db.TinyInt
  onboardingStep                         Int                                 @default(1) @map("onboarding_step") @db.TinyInt
  idVerification                         Int                                 @default(1) @map("id_verification") @db.TinyInt
  idVerifiedBy                           String?                             @map("id_verified_by") @db.VarChar(255)
  idVerificationData                     Json?                               @map("id_verification_data")
  enableSender                           Int                                 @default(0) @map("enable_sender") @db.TinyInt
  apiKey                                 String?                             @map("api_key") @db.Text
  saltKey                                String?                             @map("salt_key") @db.Text
  privateKey                             String?                             @map("private_key") @db.Text
  publicKey                              String?                             @map("public_key") @db.Text
  complianceMerchantId                   String?                             @map("compliance_merchant_id") @db.VarChar(255)
  status                                 Int                                 @default(1) @db.TinyInt
  tourStatus                             Int                                 @default(0) @map("tour_status") @db.TinyInt
  timezone                               String                              @default("Asia/Kolkata") @db.VarChar(30)
  browserId                              String?                             @map("browser_id") @db.VarChar(255)
  deviceType                             String?                             @map("device_type") @db.VarChar(255)
  rememberToken                          String?                             @map("remember_token") @db.VarChar(100)
  memo                                   String?                             @db.VarChar(255)
  createdAt                              DateTime?                           @map("created_at") @db.Timestamp(0)
  updatedAt                              DateTime?                           @updatedAt @map("updated_at") @db.Timestamp(0)
  deletedAt                              DateTime?                           @map("deleted_at") @db.Timestamp(0)
  beneficiary_account_validations        BeneficiaryAccountValidation[]
  beneficiary_accounts                   BeneficiaryAccount[]
  beneficiary_transactions               BeneficiaryTransaction[]
  beneficiary_transactions_accounts      beneficiary_transactions_accounts[]
  deposit_transactions                   DepositTransaction[]
  deposit_transactions_accounts          DepositTransactionsAccount[]
  ledgers                                Ledger[]
  merchants_merchants_user_idTousers     Merchant[]                          @relation("merchants_user_idTousers")
  quotes                                 Quote[]
  senders                                Sender[]
  teamMembers                            TeamMember[]
  documents                              UserDocument[]
  information                            UserInformation[]
  userServices                           UserService[]
  user_settings                          user_settings[]
  businessUser                           User?                               @relation("BusinessSubusers", fields: [businessUserId], references: [id], onUpdate: NoAction, map: "users_business_user_id_foreign")
  subusers                               User[]                              @relation("BusinessSubusers")
  merchants_users_merchant_idTomerchants Merchant?                           @relation("users_merchant_idTomerchants", fields: [merchantId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "users_merchant_id_foreign")
  virtualAccounts                        VirtualAccount[]
  wallet_transactions                    WalletTransaction[]
  wallets                                Wallet[]

  @@index([businessUserId], map: "users_business_user_id_foreign")
  @@index([merchantId], map: "users_merchant_id_foreign")
  @@map("users")
}

model PersonalAccessToken {
  id            BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  tokenableType String    @map("tokenable_type") @db.VarChar(255)
  tokenableId   BigInt    @map("tokenable_id") @db.UnsignedBigInt
  name          String    @db.VarChar(255)
  tokenHash     String    @unique(map: "personal_access_tokens_token_unique") @map("token") @db.VarChar(64)
  abilities     String?   @db.Text
  lastUsedAt    DateTime? @map("last_used_at") @db.Timestamp(0)
  expiresAt     DateTime? @map("expires_at") @db.Timestamp(0)
  createdAt     DateTime? @map("created_at") @db.Timestamp(0)
  updatedAt     DateTime? @updatedAt @map("updated_at") @db.Timestamp(0)

  @@index([tokenableType, tokenableId], map: "personal_access_tokens_tokenable_type_tokenable_id_index")
  @@map("personal_access_tokens")
}

model UserInformation {
  id                       BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  uniqueId                 String    @unique(map: "user_informations_unique_id_unique") @map("unique_id") @db.VarChar(255)
  userId                   BigInt    @map("user_id") @db.UnsignedBigInt
  country                  String?   @db.VarChar(100)
  address1                 String?   @map("address_1") @db.VarChar(255)
  address2                 String?   @map("address_2") @db.VarChar(255)
  city                     String?   @db.VarChar(100)
  state                    String?   @db.VarChar(100)
  postalCode               String?   @map("postal_code") @db.VarChar(50)
  purposeOfTransactions    String?   @map("purpose_of_transactions") @db.Text
  businessVerificationType String?   @map("business_verification_type") @db.VarChar(255)
  idType                   String?   @map("id_type") @db.VarChar(255)
  idNumber                 String?   @map("id_number") @db.VarChar(255)
  profession               String?   @db.VarChar(255)
  sourceOfIncome           String?   @map("source_of_income") @db.VarChar(11)
  legalName                String?   @map("legal_name") @db.VarChar(255)
  taxId                    String?   @map("tax_id") @db.VarChar(100)
  formationDate            DateTime? @map("formation_date") @db.Date
  country_of_incorporation String?   @db.VarChar(255)
  businessName             String?   @map("business_name") @db.VarChar(255)
  website                  String?   @db.VarChar(255)
  type_of_business         String?   @db.VarChar(255)
  ipAddress                String?   @map("ip_address") @db.VarChar(45)
  role                     String?   @db.VarChar(100)
  businessPersons          Json?     @map("business_persons")
  createdAt                DateTime? @map("created_at") @db.Timestamp(0)
  updatedAt                DateTime? @updatedAt @map("updated_at") @db.Timestamp(0)
  user                     User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "user_informations_user_id_foreign")

  @@index([userId], map: "user_informations_user_id_foreign")
  @@map("user_informations")
}

model UserDocument {
  id                 BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  uniqueId           String    @unique(map: "user_documents_unique_id_unique") @map("unique_id") @db.VarChar(255)
  userId             BigInt    @map("user_id") @db.UnsignedBigInt
  documentName       String?   @map("document_name") @db.VarChar(100)
  documentType       String?   @map("document_type") @db.VarChar(100)
  documentCountry    String?   @map("document_country") @db.VarChar(100)
  documentFile       String?   @map("document_file") @db.VarChar(255)
  documentBackFile   String?   @map("document_back_file") @db.VarChar(255)
  documentExpiryDate DateTime? @map("document_expiry_date") @db.Date
  status             Int       @default(1) @db.TinyInt
  verifiedAt         DateTime? @map("verified_at") @db.Timestamp(0)
  remarks            String?   @db.Text
  createdAt          DateTime? @map("created_at") @db.Timestamp(0)
  updatedAt          DateTime? @updatedAt @map("updated_at") @db.Timestamp(0)
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "user_documents_user_id_foreign")

  @@index([userId], map: "user_documents_user_id_foreign")
  @@map("user_documents")
}

model Merchant {
  id                                 BigInt            @id @default(autoincrement()) @db.UnsignedBigInt
  uniqueId                           String            @unique(map: "merchants_unique_id_unique") @map("unique_id") @db.VarChar(40)
  userId                             BigInt            @map("user_id") @db.UnsignedBigInt
  name                               String            @db.VarChar(255)
  email                              String            @unique(map: "merchants_email_unique") @db.VarChar(255)
  password                           String            @db.VarChar(255)
  apiKey                             String?           @map("api_key") @db.LongText
  saltKey                            String?           @map("salt_key") @db.LongText
  privateKey                         String?           @map("private_key") @db.LongText
  publicKey                          String?           @map("public_key") @db.LongText
  callbackUrl                        String?           @map("callback_url") @db.LongText
  telegram_channel                   String?           @db.VarChar(255)
  type                               Int               @default(1) @db.TinyInt
  status                             Int               @default(1) @db.TinyInt
  createdAt                          DateTime?         @map("created_at") @db.Timestamp(0)
  updatedAt                          DateTime?         @updatedAt @map("updated_at") @db.Timestamp(0)
  deletedAt                          DateTime?         @map("deleted_at") @db.Timestamp(0)
  settings                           MerchantSetting[]
  users_merchants_user_idTousers     User              @relation("merchants_user_idTousers", fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "merchants_user_id_foreign")
  users_users_merchant_idTomerchants User[]            @relation("users_merchant_idTomerchants")

  @@index([userId], map: "merchants_user_id_foreign")
  @@map("merchants")
}

model MerchantSetting {
  id         BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  unique_id  String    @unique(map: "merchant_settings_unique_id_unique") @db.VarChar(40)
  merchantId BigInt    @map("merchant_id") @db.UnsignedBigInt
  key        String    @db.VarChar(255)
  value      String    @db.Text
  status     Int       @default(1) @db.TinyInt
  createdAt  DateTime? @map("created_at") @db.Timestamp(0)
  updatedAt  DateTime? @updatedAt @map("updated_at") @db.Timestamp(0)
  merchant   Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "merchant_settings_merchant_id_foreign")

  @@index([merchantId], map: "merchant_settings_merchant_id_foreign")
  @@map("merchant_settings")
}

/// Polymorphic fee table introduced by migration 2025_12_29_053714.
/// `ownerType` + `ownerId` form the morph key. Possible owners:
/// - "App\\Models\\User"     - user-level fee override
/// - "App\\Models\\Merchant" - merchant-level fee override
/// - both null               - global default fee
model Fee {
  id        BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  uniqueId  String    @unique(map: "fees_unique_id_unique") @map("unique_id") @db.VarChar(255)
  ownerType String?   @map("owner_type") @db.VarChar(255)
  ownerId   BigInt?   @map("owner_id") @db.UnsignedBigInt
  feeName   String    @map("fee_name") @db.VarChar(255)
  feeType   String    @default("1") @map("fee_type") @db.VarChar(255)
  mode      String?   @db.VarChar(255)
  feeValue  Decimal   @map("fee_value") @db.Decimal(15, 6)
  currency1 String?   @map("currency_1") @db.Char(4)
  currency2 String?   @map("currency_2") @db.Char(4)
  status    Int       @default(1) @db.TinyInt
  createdAt DateTime? @map("created_at") @db.Timestamp(0)
  updatedAt DateTime? @updatedAt @map("updated_at") @db.Timestamp(0)

  @@index([ownerType, ownerId], map: "fees_owner_type_owner_id_index")
  @@map("fees")
}

model BeneficiaryAccount {
  id                         BigInt                        @id @default(autoincrement()) @db.UnsignedBigInt
  uniqueId                   String                        @unique(map: "beneficiary_accounts_unique_id_unique") @map("unique_id") @db.VarChar(255)
  userId                     BigInt?                       @map("user_id") @db.UnsignedBigInt
  team_member_id             BigInt?                       @db.UnsignedBigInt
  currency                   String                        @default("USD") @db.VarChar(3)
  country                    String                        @default("US") @db.VarChar(4)
  type                       Int?                          @default(1) @db.TinyInt
  firstName                  String?                       @map("first_name") @db.VarChar(255)
  middleName                 String?                       @map("middle_name") @db.VarChar(255)
  lastName                   String?                       @map("last_name") @db.VarChar(255)
  email                      String?                       @db.VarChar(255)
  mobileCountryCode          String?                       @map("mobile_country_code") @db.VarChar(255)
  mobile                     String?                       @db.VarChar(255)
  paymentRail                String?                       @map("payment_rail") @db.VarChar(255)
  serviceBank                String?                       @map("service_bank") @db.VarChar(255)
  bankName                   String?                       @map("bank_name") @db.VarChar(255)
  routingNumber              String?                       @map("routing_number") @db.VarChar(255)
  accountName                String?                       @map("account_name") @db.VarChar(255)
  accountNumber              String?                       @map("account_number") @db.VarChar(255)
  accountType                String?                       @map("account_type") @db.VarChar(255)
  swiftCode                  String?                       @map("swift_code") @db.VarChar(255)
  iban                       String?                       @db.VarChar(255)
  intermediaryBankSwiftCode  String?                       @map("intermediary_bank_swift_code") @db.VarChar(255)
  intermediaryBankName       String?                       @map("intermediary_bank_name") @db.VarChar(255)
  intermediaryBankAba        String?                       @map("intermediary_bank_aba") @db.VarChar(255)
  intermediaryBankAddress    String?                       @map("intermediary_bank_address") @db.VarChar(255)
  intermediaryBankCity       String?                       @map("intermediary_bank_city") @db.VarChar(255)
  intermediaryBankState      String?                       @map("intermediary_bank_state") @db.VarChar(255)
  intermediaryBankPostalCode String?                       @map("intermediary_bank_postal_code") @db.VarChar(255)
  intermediaryBankCountry    String?                       @map("intermediary_bank_country") @db.VarChar(255)
  bankCountry                String?                       @map("bank_country") @db.VarChar(3)
  businessName               String?                       @map("business_name") @db.VarChar(255)
  businessCountry            String?                       @map("business_country") @db.VarChar(3)
  externalType               String?                       @map("external_type") @db.VarChar(255)
  externalReferenceId        String?                       @map("external_reference_id") @db.VarChar(255)
  externalData               Json?                         @map("external_data")
  status                     Int                           @default(0) @db.TinyInt
  createdAt                  DateTime?                     @map("created_at") @db.Timestamp(0)
  updatedAt                  DateTime?                     @updatedAt @map("updated_at") @db.Timestamp(0)
  deletedAt                  DateTime?                     @map("deleted_at") @db.Timestamp(0)
  team_members               TeamMember?                   @relation(fields: [team_member_id], references: [id], onUpdate: NoAction, map: "beneficiary_accounts_team_member_id_foreign")
  users                      User?                         @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "beneficiary_accounts_user_id_foreign")
  additionalDetails          BeneficiaryAdditionalDetail[]
  transactions               BeneficiaryTransaction[]
  quotes                     Quote[]

  @@index([team_member_id], map: "beneficiary_accounts_team_member_id_foreign")
  @@index([userId, status], map: "beneficiary_accounts_user_id_status_index")
  @@map("beneficiary_accounts")
}

model BeneficiaryAdditionalDetail {
  id                   BigInt             @id @default(autoincrement()) @db.UnsignedBigInt
  uniqueId             String             @unique(map: "beneficiary_additional_details_unique_id_unique") @map("unique_id") @db.VarChar(255)
  beneficiaryAccountId BigInt             @map("beneficiary_account_id") @db.UnsignedBigInt
  addressType          String?            @map("address_type") @db.VarChar(255)
  addressLine1         String?            @map("address_line1") @db.VarChar(255)
  addressLine2         String?            @map("address_line2") @db.VarChar(255)
  postalCode           String?            @map("postal_code") @db.VarChar(20)
  city                 String?            @db.VarChar(255)
  state                String?            @db.VarChar(255)
  country              String?            @db.VarChar(3)
  paymentType          String?            @map("payment_type") @db.VarChar(255)
  bankAddressLine1     String?            @map("bank_address_line1") @db.VarChar(255)
  bankAddressLine2     String?            @map("bank_address_line2") @db.VarChar(255)
  bankPostalCode       String?            @map("bank_postal_code") @db.VarChar(20)
  bankCity             String?            @map("bank_city") @db.VarChar(255)
  bankState            String?            @map("bank_state") @db.VarChar(255)
  bankCountry          String?            @map("bank_country") @db.VarChar(3)
  userSourceOfIncome   String?            @map("user_source_of_income") @db.VarChar(255)
  purposeOfTransaction String?            @map("purpose_of_transaction") @db.VarChar(255)
  createdAt            DateTime?          @map("created_at") @db.Timestamp(0)
  updatedAt            DateTime?          @updatedAt @map("updated_at") @db.Timestamp(0)
  deletedAt            DateTime?          @map("deleted_at") @db.Timestamp(0)
  beneficiaryAccount   BeneficiaryAccount @relation(fields: [beneficiaryAccountId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "beneficiary_additional_details_beneficiary_account_id_foreign")

  @@index([beneficiaryAccountId], map: "beneficiary_additional_details_beneficiary_account_id_foreign")
  @@map("beneficiary_additional_details")
}

model BeneficiaryAccountValidation {
  id                  BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  uniqueId            String    @unique(map: "beneficiary_account_validations_unique_id_unique") @map("unique_id") @db.VarChar(255)
  userId              BigInt    @map("user_id") @db.UnsignedBigInt
  accountName         String?   @map("account_name") @db.VarChar(255)
  accountNumber       String    @unique(map: "beneficiary_account_validations_account_number_unique") @map("account_number") @db.VarChar(255)
  code                String?   @db.VarChar(255)
  validationService   String?   @map("validation_service") @db.VarChar(255)
  externalReferenceId String?   @map("external_reference_id") @db.VarChar(255)
  externalStatus      String?   @map("external_status") @db.VarChar(255)
  externalData        Json?     @map("external_data")
  remarks             String?   @db.Text
  isAccountExists     Int       @default(0) @map("is_account_exists") @db.TinyInt
  isNreAccount        Int       @default(0) @map("is_nre_account") @db.TinyInt
  status              Int       @default(0) @db.TinyInt
  createdAt           DateTime? @map("created_at") @db.Timestamp(0)
  updatedAt           DateTime? @updatedAt @map("updated_at") @db.Timestamp(0)
  users               User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "beneficiary_account_validations_user_id_foreign")

  @@index([userId], map: "beneficiary_account_validations_user_id_foreign")
  @@map("beneficiary_account_validations")
}

model VirtualAccount {
  id                   BigInt               @id @default(autoincrement()) @db.UnsignedBigInt
  uniqueId             String               @unique(map: "virtual_accounts_unique_id_unique") @map("unique_id") @db.VarChar(255)
  userId               BigInt?              @map("user_id") @db.UnsignedBigInt
  country              String               @default("US") @db.VarChar(100)
  currency             String               @default("USD") @db.VarChar(100)
  accountNumber        String?              @map("account_number") @db.VarChar(255)
  accountHolderName    String?              @map("account_holder_name") @db.VarChar(255)
  accountHolderAddress String?              @map("account_holder_address") @db.VarChar(255)
  accountBankName      String?              @map("account_bank_name") @db.VarChar(255)
  accountBankCode      String?              @map("account_bank_code") @db.VarChar(255)
  accountBankAddress   String?              @map("account_bank_address") @db.VarChar(255)
  routingNumber        String?              @map("routing_number") @db.VarChar(255)
  externalType         String?              @map("external_type") @db.VarChar(255)
  externalReferenceId  String?              @map("external_reference_id") @db.VarChar(255)
  externalData         Json?                @map("external_data")
  status               Int                  @default(0) @db.TinyInt
  createdAt            DateTime?            @map("created_at") @db.Timestamp(0)
  updatedAt            DateTime?            @updatedAt @map("updated_at") @db.Timestamp(0)
  depositTransactions  DepositTransaction[]
  ledgers              Ledger[]
  quotes               Quote[]
  user                 User?                @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "virtual_accounts_user_id_foreign")

  @@index([userId], map: "virtual_accounts_user_id_foreign")
  @@map("virtual_accounts")
}

model UserService {
  id                  BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  uniqueId            String    @unique(map: "user_services_unique_id_unique") @map("unique_id") @db.VarChar(255)
  userId              BigInt    @map("user_id") @db.UnsignedBigInt
  serviceType         String    @map("service_type") @db.VarChar(255)
  externalReferenceId String?   @map("external_reference_id") @db.VarChar(255)
  externalData        Json?     @map("external_data")
  externalStatus      String?   @map("external_status") @db.VarChar(255)
  status              Int       @default(1) @db.TinyInt
  isActive            Int       @default(1) @map("is_active") @db.TinyInt
  createdAt           DateTime? @map("created_at") @db.Timestamp(0)
  updatedAt           DateTime? @updatedAt @map("updated_at") @db.Timestamp(0)
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "user_services_user_id_foreign")

  @@index([userId], map: "user_services_user_id_foreign")
  @@map("user_services")
}

model Wallet {
  id           BigInt              @id @default(autoincrement()) @db.UnsignedBigInt
  uniqueId     String              @unique(map: "wallets_unique_id_unique") @map("unique_id") @db.VarChar(255)
  userId       BigInt              @map("user_id") @db.UnsignedBigInt
  currency     String              @db.VarChar(3)
  balance      Decimal             @default(0.0000) @db.Decimal(20, 4)
  status       Int                 @default(1) @db.TinyInt
  createdAt    DateTime?           @map("created_at") @db.Timestamp(0)
  updatedAt    DateTime?           @updatedAt @map("updated_at") @db.Timestamp(0)
  transactions WalletTransaction[]
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "wallets_user_id_foreign")

  @@unique([userId, currency], map: "wallets_user_id_currency_unique")
  @@index([userId, currency], map: "wallets_user_id_currency_index")
  @@map("wallets")
}

model Sender {
  id                       BigInt                   @id @default(autoincrement()) @db.UnsignedBigInt
  uniqueId                 String                   @unique(map: "senders_unique_id_unique") @map("unique_id") @db.VarChar(255)
  userId                   BigInt                   @map("user_id") @db.UnsignedBigInt
  team_member_id           BigInt?                  @db.UnsignedBigInt
  title                    String?                  @db.VarChar(5)
  firstName                String?                  @map("first_name") @db.VarChar(100)
  middleName               String?                  @map("middle_name") @db.VarChar(100)
