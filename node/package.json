{
  "name": "eficyent-api",
  "version": "1.0.0",
  "private": true,
  "description": "Eficyent fintech API (Node/TypeScript port of Laravel)",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json && npm run prisma:generate",
    "start": "node --enable-source-maps dist/index.js",
    "start:worker": "node --enable-source-maps dist/worker.js",
    "dev": "tsx watch src/index.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:db:pull": "prisma db pull",
    "prisma:studio": "prisma studio",
    "test": "jest --runInBand"
  },
  "dependencies": {
    "@aws-sdk/client-kms": "^3.668.0",
    "@aws-sdk/client-s3": "^3.668.0",
    "@aws-sdk/client-secrets-manager": "^3.668.0",
    "@aws-sdk/s3-request-presigner": "^3.668.0",
    "@prisma/client": "^5.22.0",
    "argon2": "^0.41.1",
    "bullmq": "^5.21.0",
    "compression": "^1.7.5",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "nanoid": "^5.0.8",
    "otpauth": "^9.3.4",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "rate-limit-redis": "^4.2.0",
    "uuid": "^11.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.9.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.13.0",
    "@typescript-eslint/parser": "^8.13.0",
    "eslint": "^9.14.0",
    "jest": "^29.7.0",
    "prisma": "^5.22.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
